FROM confluentinc/cp-kafka-connect:7.6.0

# Install Debezium MySQL connector and Schema Registry converter
USER root

# Create directory for Debezium connector
RUN mkdir -p /usr/share/confluent-hub-components/debezium-connector-mysql

# Download Debezium MySQL connector plugin archive
# The plugin archive contains all required JARs and dependencies
RUN curl -L -o /tmp/debezium-mysql-plugin.tar.gz \
    https://repo1.maven.org/maven2/io/debezium/debezium-connector-mysql/2.5.0.Final/debezium-connector-mysql-2.5.0.Final-plugin.tar.gz && \
    tar -xzf /tmp/debezium-mysql-plugin.tar.gz -C /usr/share/confluent-hub-components/debezium-connector-mysql --strip-components=1 && \
    rm -f /tmp/debezium-mysql-plugin.tar.gz && \
    chown -R appuser:appuser /usr/share/confluent-hub-components/debezium-connector-mysql

# Install Schema Registry Avro converter from Confluent Hub
RUN confluent-hub install --no-prompt confluentinc/kafka-connect-avro-converter:7.6.0

USER appuser

