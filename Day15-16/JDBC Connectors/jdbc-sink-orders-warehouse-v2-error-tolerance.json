{
  "name": "jdbc-sink-orders-warehouse-v2",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
    "tasks.max": "1",
    "connection.url": "jdbc:postgresql://postgres:5432/ecommerce_db",
    "connection.user": "kafka_user",
    "connection.password": "kafka_password",
    "topics": "db-query",
    "table.name.format": "orders_warehouse",
    "insert.mode": "insert",
    "pk.mode": "record_value",
    "pk.fields": "order_id",
    "batch.size": "100",
    "auto.create": "false",
    "auto.evolve": "false",
    "value.converter.schemas.enable": "true",
    "errors.tolerance": "all",
    "errors.log.enable": "true",
    "errors.deadletterqueue.topic.name": "dlq-orders",
    "errors.deadletterqueue.context.headers.enable": "true"
  }
}

